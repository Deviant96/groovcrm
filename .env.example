POSTGRES_USER=groovcrm
POSTGRES_PASSWORD=groovcrm
POSTGRES_DB=groovcrm
POSTGRES_PORT=5432

# Localhost ports for VPS host Apache reverse proxy (must match apache/crm.miretazam.com.conf)
# Use 3001 by default — many VPS hosts already use 3000 for another app.
BACKEND_HOST_PORT=3001
FRONTEND_HOST_PORT=8081

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_REMEMBER_EXPIRES_IN=30d

CORS_ORIGIN=https://crm.miretazam.com,http://localhost

ADMIN_EMAIL=admin@groovcrm.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin
